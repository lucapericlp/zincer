#!/usr/bin/env bash
set -euo pipefail

unit_name="syncdisboi-spotify-to-tidal"
on_calendar="*-*-* 12:00:00"
repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
enable_linger=false
client_id="${SPOTIFY_CLIENT_ID:-}"
client_secret="${SPOTIFY_CLIENT_SECRET:-}"

usage() {
    cat <<EOF
Usage:
  $0 --client-id <id> --client-secret <secret> [options]

Options:
  --client-id <id>          Spotify client ID. Defaults to SPOTIFY_CLIENT_ID.
  --client-secret <secret>  Spotify client secret. Defaults to SPOTIFY_CLIENT_SECRET.
  --repo-dir <path>         SyncDisBoi repo path. Defaults to this checkout.
  --on-calendar <value>     systemd OnCalendar value. Defaults to daily noon.
  --unit-name <name>        Base systemd unit name. Defaults to ${unit_name}.
  --enable-linger           Enable user lingering so the timer runs after logout.
  -h, --help                Show this help.

Examples:
  $0 --client-id abc --client-secret xyz
  SPOTIFY_CLIENT_ID=abc SPOTIFY_CLIENT_SECRET=xyz $0 --enable-linger
EOF
}

die() {
    echo "error: $*" >&2
    exit 1
}

while (($#)); do
    case "$1" in
        --client-id)
            [[ $# -ge 2 ]] || die "--client-id requires a value"
            client_id="$2"
            shift 2
            ;;
        --client-secret)
            [[ $# -ge 2 ]] || die "--client-secret requires a value"
            client_secret="$2"
            shift 2
            ;;
        --repo-dir)
            [[ $# -ge 2 ]] || die "--repo-dir requires a value"
            repo_dir="$2"
            shift 2
            ;;
        --on-calendar)
            [[ $# -ge 2 ]] || die "--on-calendar requires a value"
            on_calendar="$2"
            shift 2
            ;;
        --unit-name)
            [[ $# -ge 2 ]] || die "--unit-name requires a value"
            unit_name="$2"
            shift 2
            ;;
        --enable-linger)
            enable_linger=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "unknown argument: $1"
            ;;
    esac
done

[[ -d "$repo_dir" ]] || die "repo directory does not exist: $repo_dir"
[[ -f "$repo_dir/Cargo.toml" ]] || die "repo directory does not contain Cargo.toml: $repo_dir"
command -v systemctl >/dev/null 2>&1 || die "systemctl is required"
[[ "${EUID}" -ne 0 ]] || die "run this as the Pi user, not with sudo"

xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
systemd_user_dir="${xdg_config_home}/systemd/user"
syncdisboi_config_dir="${xdg_config_home}/SyncDisBoi"
env_file="${syncdisboi_config_dir}/spotify-to-tidal.env"
service_file="${systemd_user_dir}/${unit_name}.service"
timer_file="${systemd_user_dir}/${unit_name}.timer"
cargo_bin="$(command -v cargo || true)"
if [[ -z "$cargo_bin" ]]; then
    cargo_bin="${HOME}/.cargo/bin/cargo"
fi

systemd_escape_value() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '%s' "$value"
}

write_if_changed() {
    local src="$1"
    local dst="$2"
    local mode="$3"

    mkdir -p "$(dirname "$dst")"
    if [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
        echo "unchanged: $dst"
    else
        install -m "$mode" "$src" "$dst"
        echo "updated:   $dst"
    fi
}

if [[ -n "$client_id" || -n "$client_secret" ]]; then
    [[ -n "$client_id" ]] || die "--client-id or SPOTIFY_CLIENT_ID is required when updating credentials"
    [[ -n "$client_secret" ]] || die "--client-secret or SPOTIFY_CLIENT_SECRET is required when updating credentials"

    tmp_env="$(mktemp)"
    trap 'rm -f "${tmp_env:-}" "${tmp_service:-}" "${tmp_timer:-}"' EXIT
    {
        echo "# Generated by scripts/setup-daily-spotify-tidal-sync"
        echo "SPOTIFY_CLIENT_ID=\"$(systemd_escape_value "$client_id")\""
        echo "SPOTIFY_CLIENT_SECRET=\"$(systemd_escape_value "$client_secret")\""
        echo "CARGO_BIN=\"$(systemd_escape_value "$cargo_bin")\""
    } >"$tmp_env"
    write_if_changed "$tmp_env" "$env_file" 600
else
    [[ -f "$env_file" ]] || die "no credentials provided and no existing env file found: $env_file"
    trap 'rm -f "${tmp_service:-}" "${tmp_timer:-}"' EXIT
    echo "using existing credentials: $env_file"
fi

tmp_service="$(mktemp)"
cat >"$tmp_service" <<EOF
[Unit]
Description=SyncDisBoi Spotify to Tidal sync
Documentation=https://github.com/SilentVoid13/SyncDisBoi

[Service]
Type=oneshot
WorkingDirectory=${repo_dir}
Environment=PATH=${HOME}/.cargo/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=${env_file}
ExecStart=/usr/bin/env bash -lc 'exec "\$CARGO_BIN" run -- spotify --client-id "\$SPOTIFY_CLIENT_ID" --client-secret "\$SPOTIFY_CLIENT_SECRET" tidal'
TimeoutStartSec=2h
EOF
write_if_changed "$tmp_service" "$service_file" 644

tmp_timer="$(mktemp)"
cat >"$tmp_timer" <<EOF
[Unit]
Description=Run SyncDisBoi Spotify to Tidal sync daily at noon

[Timer]
OnCalendar=${on_calendar}
Persistent=true
Unit=${unit_name}.service

[Install]
WantedBy=timers.target
EOF
write_if_changed "$tmp_timer" "$timer_file" 644

systemctl --user daemon-reload
systemctl --user enable --now "${unit_name}.timer"

if [[ "$enable_linger" == true ]]; then
    if command -v loginctl >/dev/null 2>&1; then
        if loginctl enable-linger "$USER" 2>/dev/null; then
            echo "enabled lingering for user: $USER"
        elif command -v sudo >/dev/null 2>&1; then
            sudo loginctl enable-linger "$USER"
            echo "enabled lingering for user: $USER"
        else
            echo "warning: could not enable lingering; run: sudo loginctl enable-linger \"$USER\"" >&2
        fi
    else
        echo "warning: loginctl not found; user timers may require an active login session" >&2
    fi
fi

echo
echo "Timer installed:"
systemctl --user list-timers --all "${unit_name}.timer" || true
echo
echo "Logs:"
echo "  journalctl --user -u ${unit_name}.service"
echo
echo "Manual test run:"
echo "  systemctl --user start ${unit_name}.service"
